{
  "name": "basecrude",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','.turbo']) { try { fs.rmSync(p,{recursive:true,force:true}); } catch {} }\"",
    "build": "next build",
    "rebuild": "npm run clean && npm run build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.5.12",
    "openai": "^6.25.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "node-domexception": "npm:node-domexception@2.0.2"
  },
  "engines": {
    "node": "20.x"
  }
}
